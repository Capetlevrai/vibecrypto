# ─────────────────────────────────────────────────────────────
# VibeCrypto — variables d'environnement
# Copie ce fichier en .env.local et renseigne les clés.
# ─────────────────────────────────────────────────────────────

# Base de données Turso (libSQL)
# Dev local : laisse vide pour utiliser un fichier ./local.db
# Prod      : crée une DB sur https://turso.tech et colle les identifiants
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Secret protégeant l'endpoint d'ingestion /api/cron/refresh
# Génère un secret aléatoire :  node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
# En prod, ne PAS exposer ce secret côté client.
# Optionnel: si tu veux un bouton "Actualiser" dans l'app en prod, crée un SECOND secret
# public (moins sensible) via NEXT_PUBLIC_CRON_SECRET — utilisé uniquement pour le refresh manuel.
CRON_SECRET=
NEXT_PUBLIC_CRON_SECRET=

# ── CryptoPanic (agrégateur de news, token gratuit) ──
# Crée un compte sur https://cryptopanic.com puis https://cryptopanic.com/api/
CRYPTOPANIC_TOKEN=

# ── Résumé FR automatique à l'ingestion ──
# Chaque nouvel article est résumé en français au moment du fetch (garde-fous).
# Voir docs/INGESTION.md.
AUTO_SUMMARIZE=1
AUTO_SUMMARIZE_MAX=12
AUTO_SUMMARIZE_CONCURRENCY=2
# AUTO_SUMMARIZE_MODEL=  # id de modèle (cf src/lib/ai.ts), sinon 1er dispo
# Forfait GLM coding = rate-limit en rafale: garder une concurrence basse (1-2).

# Plafond d'articles conservés par source et par run (0 = illimité)
INGEST_PER_SOURCE_MAX=40

# ── IA multi-modèles pour les résumés ──
# Renseigne les clés des providers que tu veux activer.
# L'app n'expose que les modèles dont la clé est présente.

# GLM via Z.AI (recommandé pour GLM-4.6 / 5.x)
ZAI_API_KEY=
ZAI_BASE_URL=https://api.z.ai/api/paas/v4
ZAI_MODEL=glm-4.6

# GLM / autres via OpenRouter (https://openrouter.ai)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=zai/glm-4.6

# xAI Grok (https://x.ai/api) — résumés & analyses
XAI_API_KEY=
XAI_MODEL=grok-4-fast

# Anthropic Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# OpenAI (optionnel)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
